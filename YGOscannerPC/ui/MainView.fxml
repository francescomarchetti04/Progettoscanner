<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="YGOScannerPC.main.MainController">

    <!-- TOP BAR -->
    <top>
        <HBox spacing="15" padding="10">
            <Label text="YGO Scanner PC" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="espStatusLabel" text="ESP32: Disconnected" />
        </HBox>
    </top>

    <!-- CENTER CONTENT -->
    <center>
        <VBox spacing="10" padding="15">

            <HBox spacing="20">
                <Label text="Totale Carte:" />
                <Label fx:id="totalCardsLabel" text="0" />
            </HBox>

            <TableView fx:id="cardsTable" prefHeight="400">
                <columns>
                    <TableColumn fx:id="nameColumn" text="Nome" prefWidth="200"/>
                    <TableColumn fx:id="codeColumn" text="Codice" prefWidth="150"/>
                    <TableColumn fx:id="hashColumn" text="Hash" prefWidth="300"/>
                    <TableColumn fx:id="dateColumn" text="Data Scansione" prefWidth="180"/>
                </columns>
            </TableView>

        </VBox>
    </center>

    <!-- BOTTOM BUTTONS -->
    <bottom>
        <HBox spacing="15" padding="10" alignment="CENTER_RIGHT">
            <Button text="Importa da Android" onAction="#handleImport"/>
            <Button text="Sync ESP32" onAction="#handleSync"/>
            <Button text="Export CSV" onAction="#handleExport"/>
            <Button text="Refresh" onAction="#handleRefresh"/>
        </HBox>
    </bottom>

</BorderPane>